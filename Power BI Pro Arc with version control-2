/*

- COLOR SYSTEM — WCAG AA accessible, semantically distinct
- Source       #0055A4  deep blue      (data origin)
- Ingest       #B85C00  burnt orange   (movement/ETL)
- Storage      #1A6B40  deep green     (persistence)
- Semantic     #5C3A9E  deep violet    (logic/model)
- Reports      #0B6373  deep teal      (presentation)
- Distribution #9C2C2C  deep red       (delivery)
- Security     #374151  slate          (cross-cutting concern)
- VersionCtrl  #6B4E00  dark amber     (engineering)
- Constraint   #B85C00  same as ingest (warning = limit)
  */
  :root {
  –c-src:  #0055A4;
  –c-ing:  #B85C00;
  –c-sto:  #1A6B40;
  –c-sem:  #5C3A9E;
  –c-rep:  #0B6373;
  –c-dis:  #9C2C2C;
  –c-sec:  #374151;
  –c-vc:   #6B4E00;

```
--bg:       #F4F6F9;
--surface:  #FFFFFF;
--border:   #D8DCE4;
--rail:     #C8CDD8;
--text:     #111827;
--text-2:   #374151;
--text-3:   #6B7280;
--warn-bg:  #FFF3E0;
--warn-bd:  #D97706;
--warn-tx:  #7C3A00;
```

}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Inter’, sans-serif;
font-size: 13px;
line-height: 1.5;
-webkit-font-smoothing: antialiased;
}

.page { max-width: 1280px; margin: 0 auto; padding: 36px 32px 56px; }

/* ── HEADER ── */
header {
display: flex; align-items: flex-end; justify-content: space-between;
flex-wrap: wrap; gap: 14px;
border-bottom: 2px solid var(–text);
padding-bottom: 18px; margin-bottom: 28px;
}
header h1 { font-size: 1.35rem; font-weight: 700; letter-spacing: -0.02em; }
header p  { margin-top: 3px; font-size: 0.72rem; color: var(–text-3); font-family: ‘JetBrains Mono’, monospace; }
.hpills   { display: flex; flex-wrap: wrap; gap: 7px; align-items: flex-end; }
.hpill {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.65rem; padding: 3px 9px;
border-radius: 3px; border: 1px solid; white-space: nowrap;
}
.hp-b { color: var(–c-src); border-color: var(–c-src); background: #EBF2FF; }
.hp-g { color: var(–c-sto); border-color: var(–c-sto); background: #EBF6EF; }
.hp-a { color: var(–c-vc);  border-color: var(–c-vc);  background: #FEF8E7; }

/* ── CANVAS ── */
.canvas {
display: grid;
grid-template-columns: 1fr 280px;
gap: 20px;
align-items: start;
}

/* ── PIPELINE ── */
.pipeline { display: flex; flex-direction: column; }

/* Each pipeline row = label + cards side by side */
.p-row {
display: grid;
grid-template-columns: 80px 1fr;
gap: 0;
}

.p-label {
display: flex; align-items: center; justify-content: flex-end;
padding: 14px 12px 14px 0;
border-right: 2px solid var(–rail);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.58rem; font-weight: 500;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–text-3);
white-space: nowrap;
}

.p-body { padding: 10px 0 10px 14px; }

/* Arrow connector */
.p-arrow {
display: grid;
grid-template-columns: 80px 1fr;
}
.p-arrow-rail {
border-right: 2px solid var(–rail);
display: flex; align-items: center; justify-content: flex-end;
padding-right: 0;
}
.p-arrow-body {
padding-left: 14px;
display: flex; align-items: center; gap: 40px;
height: 22px;
}
.arr { display: flex; flex-direction: column; align-items: center; }
.arr-line { width: 1px; height: 14px; background: var(–text-3); opacity: 0.35; }
.arr-tip  { width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 5px solid var(–text-3); opacity: 0.35; }

/* ── CARD GRID ── */
/* Use a responsive auto-fill grid instead of flex to prevent overlap */
.card-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
gap: 8px;
}
.card-grid.two   { grid-template-columns: repeat(2, 1fr); }
.card-grid.three { grid-template-columns: repeat(3, 1fr); }
.card-grid.one   { grid-template-columns: 1fr; }

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 4px;
padding: 10px 11px;
min-width: 0;
}

.card-head {
display: flex; align-items: center; gap: 6px;
margin-bottom: 7px;
}
.card-icon { width: 18px; height: 18px; flex-shrink: 0; }
.card-title {
font-size: 0.7rem; font-weight: 600;
color: var(–text); line-height: 1.3;
}

.tags { display: flex; flex-wrap: wrap; gap: 4px; }
.tag {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.6rem; padding: 2px 6px;
border-radius: 2px;
background: var(–bg);
border: 1px solid var(–border);
color: var(–text-2);
white-space: nowrap;
}
.tag-l { border-left-width: 2px; }
.tag-warn {
background: var(–warn-bg); border-color: var(–warn-bd);
color: var(–warn-tx); font-weight: 500;
}

/* ── WORKSPACE FRAME ── */
.ws-frame {
border: 1.5px solid #93C5FD;
border-radius: 5px;
background: #F0F6FF;
overflow: hidden;
margin: 2px 0;
}
.ws-banner {
background: #DBEAFE;
border-bottom: 1px solid #93C5FD;
padding: 5px 12px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.62rem; font-weight: 500;
color: #1E40AF; letter-spacing: 0.04em;
display: flex; align-items: center; gap: 7px;
}
.ws-body { padding: 10px; display: flex; flex-direction: column; gap: 10px; }
.ws-section-label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.57rem; font-weight: 500;
letter-spacing: 0.1em; text-transform: uppercase;
margin-bottom: 5px;
}

/* Workspace grid — same auto-fill approach */
.ws-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 7px; }

/* ── SCALE-UP NOTE ── */
.scaleup {
display: grid; grid-template-columns: 80px 1fr;
margin-top: 2px;
}
.scaleup-rail { border-right: 2px solid var(–rail); }
.scaleup-body {
margin-left: 14px;
border: 1px dashed #9CA3AF;
border-radius: 4px;
background: #F9FAFB;
padding: 10px 13px;
}
.scaleup-body h4 {
font-size: 0.68rem; font-weight: 600;
color: var(–text-2); margin-bottom: 6px;
}

/* ── VERSION CONTROL SIDEBAR ── */
.vc-sidebar {
display: flex; flex-direction: column; gap: 13px;
border-left: 3px solid #C9A227;
padding-left: 16px;
}
.vc-hdr { padding-bottom: 10px; border-bottom: 1px solid var(–border); }
.vc-hdr h2 {
font-size: 0.72rem; font-weight: 700;
letter-spacing: 0.08em; text-transform: uppercase;
color: var(–c-vc); margin-bottom: 3px;
display: flex; align-items: center; gap: 7px;
}
.vc-hdr p { font-size: 0.67rem; color: var(–text-3); }

.vc-sec { display: flex; flex-direction: column; gap: 5px; }
.vc-sec-title {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.58rem; font-weight: 500;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–c-vc); opacity: 0.85;
}
.vc-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: 4px; padding: 10px 11px;
}

/* Branch diagram */
.branch {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.63rem; line-height: 2;
background: #F9FAFB; border: 1px solid var(–border);
border-radius: 4px; padding: 9px 12px;
color: var(–text-2); white-space: pre;
}
.bm { color: #1D4ED8; font-weight: 600; }
.bd { color: #166534; font-weight: 600; }
.bn { color: var(–text-3); }

/* Steps */
.steps { display: flex; flex-direction: column; gap: 8px; }
.step  { display: flex; gap: 8px; align-items: flex-start; }
.snum {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.58rem; font-weight: 600;
width: 18px; height: 18px; border-radius: 50%;
border: 1.5px solid #C9A227; color: var(–c-vc);
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; margin-top: 1px;
}
.stxt { font-size: 0.67rem; color: var(–text-2); line-height: 1.5; }
.stxt strong { color: var(–text); font-weight: 600; }

/* VC table */
.vc-tbl { width: 100%; border-collapse: collapse; }
.vc-tbl td {
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.61rem; padding: 3px 6px;
border-bottom: 1px solid var(–border);
color: var(–text-2);
}
.vc-tbl td:first-child { width: 16px; font-weight: 600; }
.vc-tbl tr:last-child td { border-bottom: none; }
.ty { color: #166534; }
.tn { color: #9C2C2C; }

/* ── LEGEND ── */
.legend {
margin-top: 26px; padding-top: 14px;
border-top: 1px solid var(–border);
display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
}
.leg-title {
font-size: 0.62rem; font-weight: 600;
letter-spacing: 0.08em; text-transform: uppercase;
color: var(–text-3);
}
.leg-item { display: flex; align-items: center; gap: 5px; font-size: 0.67rem; color: var(–text-2); }
.leg-dot  { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* ── FOOTER ── */
footer {
margin-top: 18px; padding-top: 14px;
border-top: 1px solid var(–border);
display: flex; justify-content: space-between; flex-wrap: wrap; gap: 6px;
}
footer p { font-family: ‘JetBrains Mono’, monospace; font-size: 0.61rem; color: var(–text-3); }

/* ── Card top-color accent ── */
.ct-src  { border-top: 2.5px solid var(–c-src); }
.ct-ing  { border-top: 2.5px solid var(–c-ing); }
.ct-sto  { border-top: 2.5px solid var(–c-sto); }
.ct-sem  { border-top: 2.5px solid var(–c-sem); }
.ct-rep  { border-top: 2.5px solid var(–c-rep); }
.ct-dis  { border-top: 2.5px solid var(–c-dis); }
.ct-sec  { border-top: 2.5px solid var(–c-sec); }
.ct-vc   { border-top: 2.5px solid var(–c-vc);  }
.tl-src  { border-left-color: var(–c-src); }
.tl-ing  { border-left-color: var(–c-ing); }
.tl-sto  { border-left-color: var(–c-sto); }
.tl-sem  { border-left-color: var(–c-sem); }
.tl-rep  { border-left-color: var(–c-rep); }
.tl-dis  { border-left-color: var(–c-dis); }
.tl-sec  { border-left-color: var(–c-sec); }
.tl-vc   { border-left-color: var(–c-vc);  }

@media (max-width: 900px) {
.canvas { grid-template-columns: 1fr; }
.vc-sidebar { border-left: none; border-top: 3px solid #C9A227; padding-left: 0; padding-top: 14px; }
.card-grid.three { grid-template-columns: repeat(2, 1fr); }
}
