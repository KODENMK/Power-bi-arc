<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Power BI Pro Workspace Architecture</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600&display=swap');

:root {
–gold: #F0A500;
–gold-light: #FFD166;
–blue: #0078D4;
–blue-bright: #40B4FF;
–teal: #00B4D8;
–bg: #060C14;
–surface: #0D1B2A;
–border: rgba(0,120,212,0.3);
–text: #C8D8E8;
–muted: #607080;
}

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Exo 2’, sans-serif;
min-height: 100vh;
}

body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image:
linear-gradient(rgba(0,120,212,0.04) 1px, transparent 1px),
linear-gradient(90deg, rgba(0,120,212,0.04) 1px, transparent 1px);
background-size: 40px 40px;
pointer-events: none;
}

.page {
max-width: 1300px;
margin: 0 auto;
padding: 40px 30px 60px;
}

header {
display: flex;
align-items: flex-start;
justify-content: space-between;
margin-bottom: 48px;
padding-bottom: 24px;
border-bottom: 1px solid var(–border);
flex-wrap: wrap;
gap: 12px;
}

.header-left h1 {
font-family: ‘Rajdhani’, sans-serif;
font-size: 2.6rem;
font-weight: 700;
letter-spacing: 0.08em;
line-height: 1;
color: #fff;
}

.header-left h1 span { color: var(–gold); }

.header-left p {
margin-top: 8px;
font-size: 0.85rem;
color: var(–muted);
letter-spacing: 0.12em;
text-transform: uppercase;
font-family: ‘Share Tech Mono’, monospace;
}

.badge {
background: linear-gradient(135deg, #0050A0, #0078D4);
border: 1px solid var(–blue-bright);
border-radius: 4px;
padding: 6px 16px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.75rem;
letter-spacing: 0.15em;
color: var(–blue-bright);
text-transform: uppercase;
white-space: nowrap;
}

.arch { display: flex; flex-direction: column; gap: 14px; }

.row { display: flex; gap: 14px; align-items: stretch; }

.row-label {
writing-mode: vertical-rl;
text-orientation: mixed;
transform: rotate(180deg);
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.63rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–muted);
min-width: 20px;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}

.row-content { flex: 1; display: flex; gap: 14px; }

.layer {
border: 1px solid;
border-radius: 6px;
padding: 14px 16px;
position: relative;
flex: 1;
transition: box-shadow 0.2s;
}

.layer:hover { box-shadow: 0 0 20px rgba(0,120,212,0.15); }

.layer-title {
font-family: ‘Rajdhani’, sans-serif;
font-size: 0.68rem;
font-weight: 600;
letter-spacing: 0.2em;
text-transform: uppercase;
margin-bottom: 10px;
display: flex;
align-items: center;
gap: 7px;
}

.layer-title::before {
content: ‘’;
width: 7px; height: 7px;
border-radius: 50%;
flex-shrink: 0;
}

.l-source { border-color: rgba(0,180,216,0.35); background: rgba(0,180,216,0.04); }
.l-source .layer-title { color: var(–teal); }
.l-source .layer-title::before { background: var(–teal); box-shadow: 0 0 5px var(–teal); }

.l-ingest { border-color: rgba(240,165,0,0.35); background: rgba(240,165,0,0.04); }
.l-ingest .layer-title { color: var(–gold); }
.l-ingest .layer-title::before { background: var(–gold); box-shadow: 0 0 5px var(–gold); }

.l-storage { border-color: rgba(0,120,212,0.4); background: rgba(0,120,212,0.05); }
.l-storage .layer-title { color: var(–blue-bright); }
.l-storage .layer-title::before { background: var(–blue-bright); box-shadow: 0 0 5px var(–blue-bright); }

.l-semantic { border-color: rgba(160,100,220,0.4); background: rgba(160,100,220,0.04); }
.l-semantic .layer-title { color: #C87DFF; }
.l-semantic .layer-title::before { background: #C87DFF; box-shadow: 0 0 5px #C87DFF; }

.l-report { border-color: rgba(0,200,100,0.35); background: rgba(0,200,100,0.04); }
.l-report .layer-title { color: #4DEFA0; }
.l-report .layer-title::before { background: #4DEFA0; box-shadow: 0 0 5px #4DEFA0; }

.l-access { border-color: rgba(240,80,80,0.3); background: rgba(240,80,80,0.04); }
.l-access .layer-title { color: #FF7070; }
.l-access .layer-title::before { background: #FF7070; box-shadow: 0 0 5px #FF7070; }

.l-gov { border-color: rgba(200,150,50,0.3); background: rgba(200,150,50,0.04); }
.l-gov .layer-title { color: #E8B84B; }
.l-gov .layer-title::before { background: #E8B84B; box-shadow: 0 0 5px #E8B84B; }

.chips { display: flex; flex-wrap: wrap; gap: 6px; }

.chip {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.7rem;
padding: 4px 10px;
border-radius: 3px;
border: 1px solid;
letter-spacing: 0.03em;
cursor: default;
transition: all 0.15s;
}

.chip:hover { filter: brightness(1.3); transform: translateY(-1px); }

.c-teal   { border-color: rgba(0,180,216,0.5);   color: #80E0F8; background: rgba(0,180,216,0.1); }
.c-gold   { border-color: rgba(240,165,0,0.5);   color: #FFD470; background: rgba(240,165,0,0.1); }
.c-blue   { border-color: rgba(0,120,212,0.5);   color: #80C4FF; background: rgba(0,120,212,0.1); }
.c-purple { border-color: rgba(160,100,220,0.5); color: #D4A0FF; background: rgba(160,100,220,0.1); }
.c-green  { border-color: rgba(0,200,100,0.5);   color: #80FFB8; background: rgba(0,200,100,0.1); }
.c-red    { border-color: rgba(240,80,80,0.4);   color: #FFB0B0; background: rgba(240,80,80,0.08); }
.c-amber  { border-color: rgba(200,150,50,0.5);  color: #F5CC80; background: rgba(200,150,50,0.1); }

.flow {
display: flex;
justify-content: center;
padding: 1px 0;
gap: 48px;
}

.flow-arrow { display: flex; flex-direction: column; align-items: center; }
.fa-line { width: 1px; height: 16px; background: linear-gradient(180deg, transparent, rgba(0,120,212,0.5)); }
.fa-head { width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 6px solid rgba(0,120,212,0.5); }

.workspace-frame {
border: 2px solid rgba(0,120,212,0.4);
border-radius: 10px;
padding: 8px;
background: rgba(0,120,212,0.02);
position: relative;
display: flex;
flex-direction: column;
gap: 12px;
}

.workspace-tag {
position: absolute;
top: -11px;
left: 20px;
background: var(–bg);
padding: 0 10px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.63rem;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–blue-bright);
border: 1px solid rgba(0,120,212,0.4);
border-radius: 2px;
}

.notes-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 12px;
margin-top: 20px;
}

.note-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 6px;
padding: 14px 16px;
}

.note-card h4 {
font-family: ‘Rajdhani’, sans-serif;
font-size: 0.73rem;
font-weight: 600;
letter-spacing: 0.15em;
text-transform: uppercase;
color: var(–gold);
margin-bottom: 8px;
}

.note-card ul { list-style: none; display: flex; flex-direction: column; gap: 5px; }

.note-card ul li {
font-size: 0.71rem;
color: var(–text);
display: flex;
gap: 5px;
line-height: 1.4;
}

.note-card ul li::before { content: ‘›’; color: var(–muted); flex-shrink: 0; }

.limits-bar {
margin-top: 14px;
display: flex;
gap: 10px;
flex-wrap: wrap;
}

.limit-tag {
background: rgba(240,165,0,0.08);
border: 1px solid rgba(240,165,0,0.3);
border-radius: 3px;
padding: 4px 11px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.67rem;
color: var(–gold-light);
letter-spacing: 0.05em;
}

.limit-tag span { color: var(–muted); margin-right: 4px; }

footer {
margin-top: 28px;
padding-top: 14px;
border-top: 1px solid var(–border);
display: flex;
justify-content: space-between;
align-items: center;
flex-wrap: wrap;
gap: 8px;
}

footer p {
font-family: ‘Share Tech Mono’, monospace;
font-size: 0.64rem;
color: var(–muted);
letter-spacing: 0.1em;
}

.pulse-dot {
display: inline-block;
width: 6px; height: 6px;
background: #4DEFA0;
border-radius: 50%;
margin-right: 6px;
animation: pulse 2s infinite;
}

@keyframes pulse {
0%, 100% { opacity: 1; box-shadow: 0 0 4px #4DEFA0; }
50% { opacity: 0.4; box-shadow: none; }
}

@media (max-width: 900px) {
.row-content { flex-direction: column; }
.notes-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
.notes-grid { grid-template-columns: 1fr; }
.header-left h1 { font-size: 1.8rem; }
}
</style>

</head>
